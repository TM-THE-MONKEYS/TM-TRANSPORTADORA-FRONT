# API FastAPI — local: http://127.0.0.1:8000 | produção Render:
# https://tm-transportadora-api.onrender.com
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# URL pública do front (Vercel / local)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# false = usa API real quando NEXT_PUBLIC_API_URL está definida
# true  = mocks in-memory (lib/mocks)
NEXT_PUBLIC_USE_MOCKS=false
