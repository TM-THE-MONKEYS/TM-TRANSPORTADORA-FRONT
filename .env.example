# Backend FastAPI — Railway (prod) ou local (http://127.0.0.1:8000)
NEXT_PUBLIC_API_URL=https://api-production-a071.up.railway.app

# URL pública do front (local ou Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# false = API real | true = mocks (dev sem backend)
NEXT_PUBLIC_USE_MOCKS=false

# Dev + Railway: o Next faz proxy de /api/v1 → NEXT_PUBLIC_API_URL (CORS do Railway não inclui localhost).

# Opcional: cron Vercel (NÃO vai no .env.local do dev; só no painel Vercel)
# CRON_SECRET=

# Opcional: branding
# NEXT_PUBLIC_LOGIN_IMAGE=/branding/login.jpg
# NEXT_PUBLIC_NAVBAR_LOGO=/branding/logo.png
# NEXT_PUBLIC_NAVBAR_LOGO_DARK=/branding/logo-dark.png
